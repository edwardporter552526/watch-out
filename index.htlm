<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Look Out For Us | Official Support</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            color: #333;
            text-align: center;
            padding: 50px 20px;
        }
        .container {
            max-width: 600px;
            margin: auto;
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        h1 { color: #2c3e50; }
        p { line-height: 1.6; }
        
        /* Button Styles */
        .btn-container {
            margin-top: 30px;
        }
        .app-btn {
            display: inline-block;
            background-color: #007bff;
            color: white;
            padding: 12px 25px;
            text-decoration: none;
            border-radius: 8px;
            font-weight: bold;
            transition: background 0.3s;
            margin: 10px;
        }
        .app-btn:hover {
            background-color: #0056b3;
        }
        .contact-info {
            margin-top: 40px;
            font-size: 0.9em;
            color: #7f8c8d;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>Look Out For Us</h1>
        <p>The mobile app designed for your security and connection. Download now on your favorite platform.</p>

        <div class="btn-container">
            <a href="#" class="app-btn" id="ios-link">App Store</a>
            <a href="#" class="app-btn" id="android-link">Google Play</a>
        </div>

        <div class="contact-info">
            <p>For support or payment inquiries, please contact:</p>
            <strong>Edward Porter</strong><br>
            <a href="mailto:eporter@usa.com">eporter@usa.com</a>
        </div>
    </div>

    <script>
        // Placeholder for future dynamic link logic
        document.getElementById('ios-link').addEventListener('click', function(e) {
            console.log("Redirecting to iOS App Store...");
        });
        
        document.getElementById('android-link').addEventListener('click', function(e) {
            console.log("Redirecting to Google Play Store...");
        });
    </script>

</body>
</html>
