<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WATCH OUT FOR ME | OFFICIAL</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #000000; color: #ffffff; font-family: 'Inter', sans-serif; overflow-x: hidden; }
        .noir-card { background: #0a0a0a; border: 1px solid #1a1a1a; border-radius: 2rem; }
        .glitch { text-shadow: 2px 0 #3b82f6, -2px 0 #ef4444; }
        .hidden { display: none !important; }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-center p-6 text-center">

    <div id="landing" class="w-full max-w-md space-y-10">
        <header class="space-y-2">
            <h1 class="text-6xl font-black italic tracking-tighter glitch uppercase leading-none">
                WATCH OUT <br> FOR ME
            </h1>
            <p class="text-blue-500 font-bold tracking-[0.4em] text-[10px] uppercase">Global Safety Network</p>
        </header>

        <div class="space-y-4 pt-4">
            <a href="https://buy.stripe.com/PAYMENT_LINK" target="_blank" class="block w-full py-6 bg-white text-black font-extrabold text-lg rounded-3xl uppercase tracking-widest hover:bg-blue-600 hover:text-white transition-all">
                JOIN THE WATCH ($25)
            </a>
            
            <button onclick="toggleZelle()" class="w-full py-4 border border-white/10 text-gray-500 font-bold rounded-3xl text-[10px] uppercase tracking-widest">
                Pay with Zelle / CashApp
            </button>
        </div>

        <div id="zelle-box" class="hidden noir-card p-6 text-left space-y-4 border-blue-900/30">
            <p class="text-blue-500 font-black text-[9px] uppercase tracking-widest">Manual Activation</p>
            <p class="text-xs text-gray-400">1. Send <b>$25</b> via Zelle/CashApp to your rep.<br>2. Text your <b>Name & Email</b> to support.<br>3. Enter the <b>Member Key</b> below once confirmed.</p>
        </div>

        <div class="pt-10 border-t border-white/5">
            <p class="text-[9px] text-gray-700 font-black uppercase tracking-[0.2em] mb-4">Member Access Portal</p>
            <div class="flex gap-2">
                <input type="password" id="pass-key" placeholder="KEY" class="flex-1 bg-zinc-900 border border-white/10 p-4 rounded-2xl text-center text-sm outline-none focus:border-blue-500 text-white">
                <button onclick="checkKey()" class="bg-blue-600 px-8 rounded-2xl font-black text-xs uppercase">Enter</button>
            </div>
        </div>
    </div>

    <div id="dashboard" class="hidden w-full max-w-lg space-y-6">
        <div class="noir-card p-8 space-y-8">
            <div class="flex justify-between items-center border-b border-white/5 pb-4">
                <h2 class="text-2xl font-black italic uppercase tracking-tighter">Supervisor</h2>
                <span class="text-[10px] text-green-500 font-bold animate-pulse">● LIVE</span>
            </div>
            
            <div class="bg-black/50 p-6 rounded-3xl border border-white/5">
                <p class="text-blue-500 text-[9px] font-black uppercase mb-1">AI Node Strength</p>
                <p class="text-4xl font-black italic">99.8%</p>
            </div>

            <textarea placeholder="Enter Network Command..." class="w-full bg-black border border-white/10 rounded-3xl p-6 h-32 outline-none focus:border-blue-500 italic text-sm text-gray-300"></textarea>
            
            <button onclick="alert('Scanning Network...')" class="w-full py-5 bg-blue-600 rounded-3xl font-black uppercase tracking-widest text-xs">Execute Security Scan</button>
            
            <button onclick="location.reload()" class="w-full py-4 text-gray-600 font-bold text-[10px] uppercase tracking-widest">Logout System</button>
        </div>
    </div>

    <script>
        function toggleZelle() {
            document.getElementById('zelle-box').classList.toggle('hidden');
        }

        function checkKey() {
            const key = document.getElementById('pass-key').value.toUpperCase();
            // Your Master Key
            if(key === 'WATCH2024' || key === 'STEALTH') {
                document.getElementById('landing').classList.add('hidden');
                document.getElementById('dashboard').classList.remove('hidden');
            } else {
                alert('ACCESS DENIED. Check payment status.');
            }
        }
    </script>
</body>
</html>
